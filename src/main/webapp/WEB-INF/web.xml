    </servlet>
    <servlet-mapping>
        <servlet-name>fd</servlet-name>
        <url-pattern>/fd</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>fz</servlet-name>
        <servlet-class>com.dlt.fz</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>fz</servlet-name>
        <url-pattern>/fz</url-pattern>
    </servlet-mapping>
	
	<servlet>
		<servlet-name>hrso</servlet-name>
