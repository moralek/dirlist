		<servlet-name>del</servlet-name>
		<url-pattern>/del</url-pattern>
	</servlet-mapping>
	
	<servlet>
		<servlet-name>si</servlet-name>
		<servlet-class>com.dlt.si</servlet-class>
	</servlet>
	
	<servlet-mapping>
		<servlet-name>si</servlet-name>
		<url-pattern>/si</url-pattern>
	</servlet-mapping>
	
	<servlet>
		<servlet-name>up</servlet-name>
		<servlet-class>com.dlt.up</servlet-class>
	</servlet>
	
	<servlet-mapping>
		<servlet-name>up</servlet-name>
		<url-pattern>/up</url-pattern>
	</servlet-mapping>


    <welcome-file-list>
        <welcome-file>list</welcome-file>
    </welcome-file-list>

</web-app>
